{
  "expo": {
    "name": "AgendaBot",
    "slug": "agendabot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C47FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.agendabot.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C47FF"
      },
      "package": "com.agendabot.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Necessário para escanear QR codes." }
      ]
    ],
    "scheme": "agendabot",
    "experiments": {
      "typedRoutes": true
    }
  }
}
